# CypherAI Official Backend
PORT=8787
HOST=0.0.0.0

# Required AI miner capability
REQUIRED_AI_MODEL=CypherTroopers/cypheriumai-light-v1-alpha
MIN_AI_MEMORY_GB=32

# Registry storage
AI_REGISTRY_PATH=./data/ai-nodes.json
AI_CHALLENGE_PATH=./data/ai-challenges.json

# Timers
CHALLENGE_TTL_MS=300000
HEALTH_CHECK_INTERVAL_MS=60000
NODE_STALE_AFTER_MS=180000
MAX_HEALTH_FAILURES=3

# RPC request timeout
RPC_TIMEOUT_MS=8000
